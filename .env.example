# Copy this file to .env and fill in values for your Snowflake test account.
# Example:
#   cp .env.example .env
#   set -a && source .env && set +a

SNOWFLAKE_TEST_ACCOUNT=your_account_identifier
SNOWFLAKE_TEST_USER=your_username
SNOWFLAKE_TEST_PASSWORD=your_password
SNOWFLAKE_TEST_AUTHENTICATOR=snowflake
SNOWFLAKE_TEST_ROLE=your_role
SNOWFLAKE_TEST_DATABASE=your_database
SNOWFLAKE_TEST_WAREHOUSE=your_warehouse
SNOWFLAKE_TEST_SCHEMA=SF_AI_INTEGRATION_TESTS

# Set to true only when you want dbt to create/train Snowflake AI objects in
# integration_tests/models/*_example.sql. Default test runs only parse those
# examples and run DDL macro assertion tests.
DBT_VARS='{"sf_ai_enable_ai_integration_tests": false}'
